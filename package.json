{
  "name": "@codecrafters/redis",
  "version": "1.0.0",
  "description": "Redis server implementation",
  "main": "app/main.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint app/**/*.js",
    "lint:fix": "eslint app/**/*.js --fix",
    "start": "node app/main.js"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "rootDir": ".",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "app/**/*.js",
      "!app/main.js"
    ]
  }
}